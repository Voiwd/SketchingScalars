# .gitignore para SketchingScalars
# Ignora arquivos gerados por Python, modelos, dependências do front-end, IDEs e dados

# Byte-compiled / caches
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd

# Virtual environments
venv/
env/
.venv/
ENV/

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/
*.egg

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
.coverage
coverage.xml
htmlcov/
.pytest_cache/

# Logs
*.log
logs/

# IDEs and editors
.vscode/
.idea/

# Node / Vite (frontend)
front/node_modules/
front/dist/
front/.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment variables
.env
.env.*

# Data & model artifacts
model.pth
*.pth
*.pt
back/api/data/
back/api/data/MNIST/raw/

# ML experiment tracking and tensorboard
runs/
wandb/
mlruns/

# Backup and temp files
*.bak
*~
*.tmp

# Mac / Windows
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/

# Compiled extensions
*.so
*.dll
*.dylib

# Secrets / keys
*.pem
*.key

# Misc
coverage/
htmlcov/

# Keep requirements and lockfiles tracked (don't ignore): requirements.txt, package.json, package-lock.json, yarn.lock
*.png